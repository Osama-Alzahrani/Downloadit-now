{
  "productName": "Downloadit",
  "version": "0.2.0",
  "identifier": "com.downloadit.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Downloadit",
        "width": 900,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main-capability",
          "description": "Main window capabilities",
          "windows": ["main"],
          "permissions": [
            "dialog:allow-open",
            "core:event:allow-listen",
            "core:event:allow-emit",
            "updater:allow-check",
            "updater:allow-download-and-install",
            "process:allow-restart"
          ]
        }
      ]
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU5QTE0RTc1MjhFQ0E3OTcKUldTWHArd29kVTZoV2R6MFJQZ3c4ZEhJQzMzcnV3LzBHeUxQWkZoZllpTEU5L055VEZpK2tFSzIK",
      "endpoints": [
        "https://github.com/Osama-Alzahrani/Downloadit-now/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
